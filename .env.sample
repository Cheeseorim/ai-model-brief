# Copy this file to `.env` for local runs, or add the same names as GitHub
# Actions secrets/variables in the repository settings.

# Required for natural Korean translation/summarization.
# Without this key, Model Radar falls back to deterministic Korean templates.
OPENAI_API_KEY=

# Optional OpenAI summary settings.
SUMMARY_MODEL=gpt-5.4-mini
SUMMARY_MAX_EVENTS=10

# Optional: post newly detected high-signal changes to Discord.
DISCORD_WEBHOOK_URL=

# Optional: comma-separated AWS regions queried by the collector.
BEDROCK_REGIONS=ap-northeast-2,us-east-1

# Required only when BEDROCK_REGIONS is set in an environment with AWS access.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
